# MCP Client Configuration

# Moonshot AI API Key (for LLM inference)
MOONSHOT_API_KEY=sk-your-api-key-here

# MCP Server Connection Details
# The command to execute to start the remote MCP server
MCP_SERVER_COMMAND=python

# Arguments to pass to the MCP server command (must be valid JSON)
# Example: python -m ceramicraft_mcp_server.serve
MCP_SERVER_ARGS=["- m", "ceramicraft_mcp_server.serve"]

# Zitadel OAuth Configuration (for JWT token verification)
# These are used by the remote MCP server for authentication
MCP_ZITADEL_ISSUER=https://your-zitadel-instance.com
MCP_ZITADEL_JWKS_URL=https://your-zitadel-instance.com/.well-known/jwks.json

# Test JWT Token (optional, for testing without full OAuth flow)
ZITADEL_JWT_TOKEN=eyJhbGciOiJSUzI1NiIsImtpZCI6IjEyMzQ1Njc4OTAifQ...

# Backend Microservice URLs (used by MCP server internally)
# These default to K8s service names but can be overridden
PRODUCT_MS_HTTP=http://product-ms-svc:8080
ORDER_MS_HTTP=http://order-ms-svc:8080
USER_MS_HTTP=http://user-ms-svc:8080
COMMENT_MS_HTTP=http://comment-ms-svc:8080
PAYMENT_MS_HTTP=http://payment-ms-svc:8080
NOTIFICATION_MS_HTTP=http://notification-ms-svc:8080

# Optional: Agent configuration
# Set to "true" to enable MCP integration by default
USE_MCP_INTEGRATION=true

# Optional: Logging level
LOG_LEVEL=info
