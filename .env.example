# MCP Client Configuration

# Generic LLM provider configuration
# Preferred for open-source usage. Works with OpenAI-compatible APIs.
LLM_API_KEY=sk-your-api-key-here
LLM_API_BASEURL=https://api.moonshot.cn/v1
LLM_MODEL=kimi-k2-0711-preview
LLM_VISION_MODEL=moonshot-v1-8k-vision-preview
LLM_TEMPERATURE=0
LLM_VISION_TEMPERATURE=1

# Backward-compatible alias for existing Moonshot-only setups
MOONSHOT_API_KEY=

MCP_SERVER_URL=


RUN_ENV=dev

MLFLOW_TRACKING_URI=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=


RESEND_API_KEY=
EMAIL_RECEIVER=

